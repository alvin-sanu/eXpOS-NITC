alias currentPID R0;
currentPID = [SYSTEM_STATUS_TABLE + 1];
[PROCESS_TABLE + [SYSTEM_STATUS_TABLE + 1]*16 + 4] = TERMINATED;
SP = [PROCESS_TABLE + currentPID*16 + 11]*512 - 1;

alias newPID R2;
newPID = 1;
while(newPID != 16) do
	if([PROCESS_TABLE + newPID*16 + 4] != TERMINATED) then
		call MOD_5;
	endif;
	newPID = newPID + 1;
endwhile;
halt;
