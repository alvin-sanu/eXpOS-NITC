if([SP-5] == "Write") then
	alias filedesc R1;
	filedesc = [SP - 4];
	if(filedesc == -2) then
		alias word R2;
		word = [SP - 3];
		[SP +1] = 5;
		[SP +2] = filedesc;
		[SP + 3] = word;
		[SP + 4] = R0;
		
		[SP + 5] = R0;
		SP = SP + 5;

		INT 7;

		alias retval R3;
		retval = [SP-1];
		SP = SP - 4;
	        [SP-1] = returnVal;
	        return;
        endif;
endif;
[SP-1] = -1;
return;
