alias functionNum R1;
alias currentPID R2;

if(functionNum == 3) then
	multipush(R1,R2,R3);
	R1 = 8;
	call MOD_0;
	//does not have any return value
	multipop(R1,R2,R3);
	print R3;
	multipush(R1,R2,R3);
	R1 = 9;
	call MOD_0;
	//now we dont save this return value...
	multipop(R1,R2,R3);
	return;
else
	return;
endif;
