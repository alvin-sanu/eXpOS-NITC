int main()
{
    decl
        int temp, retval;
        str filename;
    enddecl

    begin
        temp = exposcall("Write", -2, "Enter File:");
        temp = exposcall("Read", -1, filename);

        retval = exposcall("Exec", filename);

        if(retval == -1) then
            temp = exposcall("Write", -2, "error");
        endif;
        
        return 0;
    end
}