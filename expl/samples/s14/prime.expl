int main(){
	decl
		int a;
		int temp;
		int retval;
	enddecl
	begin
	a = 2;
	while(a<=100) do
		temp = 2;
		while(temp <= (a/2)) do
			if((a%temp)==0) then
				break;
			endif;
			temp = temp + 1;
		endwhile;
		if(temp > (a/2)) then
			retval = exposcall("Write",-2,a);
		endif;
		a = a + 1;
	endwhile;
	return 0;
	end
}
